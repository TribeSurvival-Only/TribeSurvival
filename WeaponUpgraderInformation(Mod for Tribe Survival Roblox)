    local function Ftoolfunction()
        for _, tool in pairs(character:GetChildren()) do
            local checktool = tool:GetAttribute("Tool")
            if checktool then
                local function contains(tbl, val)
                    for _, v in ipairs(tbl) do
                        if v == val then
                            return true
                        end
                    end
                return false
                end
                local Firsttools = {"Katana", "Decapitator", "Lance", "Sickles", "Bat", "War Club", "Scythe", "Axe", "Stick", "Sword", "GreatAxe", "Spear", "Daggers", "Club", "Polearm"}
                if contains(Firsttools, tool.Name) then
                    ME.Visible = tool:GetAttribute("MeteorEnchant") or false
                    B.Visible = tool:GetAttribute("BloodlustEnchant") or false
                    D.Visible = tool:GetAttribute("DrainingEnchant") or false
                    F.Visible = tool:GetAttribute("FrostEnchant") or false
                    S.Visible = tool:GetAttribute("SearingEnchant") or false
                    WN.Text = tool.Name
                    HD.Text = "damage to"
                    HD.TextSize = 14
                    local stats = "material"
                    local gold = 5000
                    local diamond = 12500
                    local ruby = 25000
                    local emerald = 62500
                    local currentHD = tool:GetAttribute("HitDamage")
                    if not currentHD then                        
                        HD.Text = "You need to do damage"
                        HD.TextColor3 = Color3.new(1, 1, 1)
                    else
            local damage = tonumber(currentHD)
            if damage < gold then
                stats = "gold"
                HD.Text = math.floor((gold - damage)) .. " damage to " .. stats
                HD.TextColor3 = Color3.new(255/255, 255/255, 0/255)
                HD.TextSize = 14
            elseif damage < diamond then
                stats = "diamond"
                HD.Text = math.floor((diamond - damage)) .. " damage to " .. stats
                HD.TextColor3 = Color3.new(85/255, 255/255, 255/255)
                HD.TextSize = 14
            elseif damage < ruby then
                stats = "ruby"
                HD.Text = math.floor((ruby - damage)) .. " damage to " .. stats
                HD.TextColor3 = Color3.new(255/255, 0/255, 0/255)
                HD.TextSize = 14
            elseif damage < emerald then
                stats = "emerald"
                HD.Text = math.floor((emerald - damage)) .. " damage to " .. stats
                HD.TextColor3 = Color3.new(0/255, 255/255, 0/255)
                HD.TextSize = 14
            else
                HD.Text = "Max"
                HD.TextColor3 = Color3.new(0/255, 170/255, 0/255)
                HD.TextSize = 16
            end
        end
                end
            end
        end
    end
