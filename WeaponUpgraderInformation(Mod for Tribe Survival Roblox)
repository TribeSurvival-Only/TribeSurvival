                  ME.Visible = tool:GetAttribute("MeteorEnchant") or false
                  B.Visible = tool:GetAttribute("BloodlustEnchant") or false
                  D.Visible = tool:GetAttribute("DrainingEnchant") or false
                  F.Visible = tool:GetAttribute("FrostEnchant") or false
                  S.Visible = tool:GetAttribute("SearingEnchant") or false
                  HD.TextColor3 = Color3.new(1, 1, 1)
                  WN.Text = tool.Name
                  HD.Text = "damage to"
                  HD.TextSize = 12
                  local stats = "material"
                  local gold = 5000
                  local diamond = 12500
                  local ruby = 25000
                  local emerald = 62500
