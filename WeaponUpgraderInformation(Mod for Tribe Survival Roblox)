                      end
                  end
              return false
              end
              local Meleetools = {"Katana", "Great Hammer", "Wirecutters", "Decapitator", "Lance", "Sickles", "Bat", "War Club", "Scythe", "Wrench", "Mallet", "Hammer", "Shovel", "Axe", "Stick", "Sword", "GreatAxe", "Spear", "Daggers", "Club", "Polearm"}
              local Rangedtools = {"Bow", "Molotov",  "Blowgun", "Wooden Shield", "Crossbow", "Musket", "Trident"}
