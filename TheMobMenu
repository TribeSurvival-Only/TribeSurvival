-- Menu play open and close
  local function MenuActivable()
      if not MenuVisible then
          MenuVisible = true
          SpawnMobMenu.Position = UDim2.new(0.5, 0, -0.5, 5)
          SpawnMobMenu.Visible = true
          local tweenInfo = TweenInfo.new(
              0.35,
              Enum.EasingStyle.Quad,
              Enum.EasingDirection.Out
          )
          local tween = TweenService:Create(SpawnMobMenu, tweenInfo, {Position = endOpenPosition})
          tween:Play()
      else
          MenuVisible = false
          local tweenInfo = TweenInfo.new(
              0.35,
              Enum.EasingStyle.Quad,
              Enum.EasingDirection.Out
          )
          local tween = TweenService:Create(SpawnMobMenu, tweenInfo, {Position = endClosePosition})
          tween:Play()
          tween.Completed:Connect(function()
              SpawnMobMenu.Visible = false
          end)
      end
  end
  CloseButton.MouseButton1Click:Connect(MenuActivable)
