-- Bosses&Minibosses and Default mobs
  local categories = {
      ["Default"] = {},
      ["Boss&Miniboss"] = {}
  }
  local mobsFolder = game:GetService("ReplicatedStorage"):WaitForChild("Mobs")
  for _, model in ipairs(mobsFolder:GetChildren()) do
      if model:IsA("Model") then
          local isBoss = false
          local successBoss, valueBoss = pcall(function() return model:GetAttribute("Boss") end)
          if successBoss then
              isBoss = valueBoss
          end
          print("Model:", model.Name, "Boss:", isBoss)
          if isBoss then
              table.insert(categories["Boss&Miniboss"], model)
          else
              table.insert(categories["Default"], model)
          end
      end
  end
  local containerNames = {"Default", "Boss&Miniboss"}
  local scrollFrames = {}
  local startY = 70 
  for i, categoryName in ipairs(containerNames) do
      local title = Instance.new("TextLabel")
      title.Size = UDim2.new(1, -20, 0, 20)
      title.Position = UDim2.new(0, 10, 0, startY + (i - 1) * 140)
      title.Text = categoryName
      title.BackgroundColor3 = Color3.new(0.2, 0.2, 0.2)
      title.TextColor3 = Color3.new(1, 1, 1)
      title.Parent = SpawnMobMenu
      local stroke = Instance.new("UIStroke")
      stroke.Color = Color3.new(0, 0, 0)
      stroke.Thickness = 2
      stroke.Parent = title
      local scrollFrame = Instance.new("ScrollingFrame")
      scrollFrame.Size = UDim2.new(1, -20, 0, 100)
      scrollFrame.Position = UDim2.new(0, 9, 0, startY + (i - 1) * 140 + 20)
      scrollFrame.BackgroundColor3 = Color3.new(0, 0, 0)
      scrollFrame.BorderSizePixel = 0
      scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
      scrollFrame.Parent = SpawnMobMenu
      scrollFrame.Transparency = 1
      local UIGridLayout = Instance.new("UIGridLayout")
      UIGridLayout.CellSize = UDim2.new(0, 85, 0, 30)
      UIGridLayout.SortOrder = Enum.SortOrder.LayoutOrder
      UIGridLayout.Parent = scrollFrame
      local scrollStroke = Instance.new("UIStroke")
      scrollStroke.Color = Color3.new(0, 0, 0)
      scrollStroke.Thickness = 2
      scrollStroke.Parent = scrollFrame
      scrollFrames[categoryName] = scrollFrame
  end
  local selectedModels = {}
-- SelectableModelButtons
  local function createModelButton(modelName, parentFrame)
      local btn = Instance.new("TextButton")
      btn.Size = UDim2.new(0, 100, 0, 30)
      btn.Text = modelName
      btn.BackgroundColor3 = Color3.new(0.8, 0.8, 0.8)
      btn.BorderSizePixel = 1
      btn.TextScaled = true 
      btn.TextWrapped = true 
      btn.TextColor3 = Color3.new(0, 0, 0)
      btn.Parent = parentFrame
      local isSelected = false
      btn.MouseButton1Click:Connect(function()
          isSelected = not isSelected
          if isSelected then
              btn.BackgroundColor3 = Color3.new(0.4, 0.8, 0.4)
              selectedModels[modelName] = true
          else
              btn.BackgroundColor3 = Color3.new(0.8, 0.8, 0.8)
              selectedModels[modelName] = nil
          end
      end)
  end
  for _, modelsList in pairs(categories) do
      table.sort(modelsList, function(a, b) return a.Name < b.Name end)
      local categoryName = nil
      for key, list in pairs(categories) do
          if list == modelsList then
              categoryName = key
              break
          end
      end
      local parentFrame = scrollFrames[categoryName]
      for _, model in ipairs(modelsList) do
          createModelButton(model.Name, parentFrame)
      end
    end
-- Amount label and button 
  local amountLabel = Instance.new("TextLabel")
  amountLabel.Size = UDim2.new(0, 80, 0, 20)
  amountLabel.Position = UDim2.new(0, 10, 0, startY + #containerNames * 140)
  amountLabel.Text = "Amount:"
  amountLabel.Parent = SpawnMobMenu
  amountLabel.BackgroundColor3 = Color3.new(0.2, 0.2, 0.2)
  amountLabel.TextColor3 = Color3.new(1, 1, 1)
  local amountBox = Instance.new("TextBox")
  amountBox.Size = UDim2.new(0, 100, 0, 25)
  amountBox.Position = UDim2.new(0, 100, 0, startY + #containerNames * 140)
  amountBox.Text = "1"
  amountBox.BackgroundColor3 = Color3.new(1, 1, 1)
  amountBox.Parent = SpawnMobMenu
  local sendButton = Instance.new("TextButton")
  sendButton.Size = UDim2.new(0, 100, 0, 30)
  sendButton.Position = UDim2.new(0, 210, 0, startY + #containerNames * 140)
  sendButton.Text = "Send"
  sendButton.Parent = SpawnMobMenu
  sendButton.MouseButton1Click:Connect(function()
      local amountText = amountBox.Text
      local amount = tonumber(amountText)
      if not amount then
          warn("Invalid amount")
          return
      end
      local selected = {}
      for modelName, _ in pairs(selectedModels) do
          table.insert(selected, modelName)
      end
      if #selected == 0 then
          warn("No models selected")
          return
      end
      for n = 1, amount do
          for _, modelName in ipairs(selected) do
              local args = {
                  [1] = "spawnmob " .. modelName,
                  [2] = {}
              }
              game:GetService("ReplicatedStorage"):WaitForChild("CmdrClient"):WaitForChild("CmdrFunction"):InvokeServer(unpack(args))
          end
      end
  end)
